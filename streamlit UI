# SCREEN 1 — Mode selector
# ════════════════════════════════════════════════════════════════════════════════
if st.session_state.mode is None:
    st.markdown("""
    <div class="screen-title">
        <h1>🎭 MoodBot</h1>
        <p>Choose your AI mode to begin</p>
    </div>
    """, unsafe_allow_html=True)

    for name, cfg in MODES.items():
        col_card, col_btn = st.columns([5, 1])
        with col_card:
            st.markdown(f"""
            <div class="mode-card">
                <div class="card-emoji">{cfg['emoji']}</div>
                <div class="card-info">
                    <h3 style="color:{cfg['accent']}">{cfg['label']} Agent</h3>
                    <p>{cfg['tag']}</p>
                </div>
            </div>
            """, unsafe_allow_html=True)
        with col_btn:
            st.markdown("<div style='height:18px'></div>", unsafe_allow_html=True)
            if st.button("Select", key=f"select_{name}"):
                set_mode(name)
                st.rerun()


# ════════════════════════════════════════════════════════════════════════════════
# SCREEN 2 — Chat
# ════════════════════════════════════════════════════════════════════════════════
else:
    cfg    = MODES[st.session_state.mode]
    accent = cfg["accent"]
    bu_bg  = cfg["bubble_user"]
    bu_txt = cfg["bubble_user_text"]
    bb_bg  = cfg["bubble_bot"]
    bb_bdr = cfg["bubble_bot_border"]
    av_bg  = cfg["avatar_bg"]

    st.markdown(f"""
    <style>
    .bubble.user {{ background:{bu_bg}; color:{bu_txt}; }}
    .bubble.bot  {{ background:{bb_bg}; border:1px solid {bb_bdr}; color:#dbd9f0; }}
    .avatar.bot  {{ background:{av_bg}; }}
    .avatar.user {{ background:{bu_bg}; color:{bu_txt}; font-weight:700; font-size:0.7rem; }}
    .typing span {{ background:{accent}; }}
    [data-testid="stChatInputSubmitButton"] svg {{ fill:{accent} !important; }}
    </style>
    """, unsafe_allow_html=True)

    # Header row
    h1, h2, h3 = st.columns([5, 1, 1])
    with h1:
        st.markdown(f"""
        <div class="chat-header">
            <span class="big-emoji">{cfg['emoji']}</span>
            <div>
                <h2>{cfg['label']} Agent</h2>
                <div class="mode-tag" style="color:{accent}">{cfg['tag']}</div>
            </div>
        </div>
        """, unsafe_allow_html=True)
    with h2:
        st.markdown("<div style='height:12px'></div>", unsafe_allow_html=True)
        if st.button("✕ clear"):
            st.session_state.messages = [SystemMessage(content=cfg["prompt"])]
            st.rerun()
    with h3:
        st.markdown("<div style='height:12px'></div>", unsafe_allow_html=True)
        if st.button("← back"):
            reset()
            st.rerun()

    # Message history
    chat_msgs = [m for m in st.session_state.messages if not isinstance(m, SystemMessage)]

    if not chat_msgs:
        st.markdown(f"""
        <div class="empty-state">
            <div class="es-icon">{cfg['emoji']}</div>
            <p>Start the conversation…</p>
        </div>
        """, unsafe_allow_html=True)
    else:
        for msg in chat_msgs:
            if isinstance(msg, HumanMessage):
                st.markdown(f"""
                <div class="chat-row user">
                    <div class="avatar user">YOU</div>
                    <div class="bubble user">{msg.content}</div>
                </div>""", unsafe_allow_html=True)
            elif isinstance(msg, AIMessage):
                st.markdown(f"""
                <div class="chat-row bot">
                    <div class="avatar bot">{cfg['emoji']}</div>
                    <div class="bubble bot">{msg.content}</div>
                </div>""", unsafe_allow_html=True)

    # Input
    if prompt := st.chat_input("Type a message…"):
        st.session_state.messages.append(HumanMessage(content=prompt))

        st.markdown(f"""
        <div class="chat-row user">
            <div class="avatar user">YOU</div>
            <div class="bubble user">{prompt}</div>
        </div>""", unsafe_allow_html=True)

        typing_slot = st.empty()
        typing_slot.markdown(f"""
        <div class="chat-row bot">
            <div class="avatar bot">{cfg['emoji']}</div>
            <div class="bubble bot">
                <div class="typing"><span></span><span></span><span></span></div>
            </div>
        </div>""", unsafe_allow_html=True)

        response = model.invoke(st.session_state.messages)
        st.session_state.messages.append(AIMessage(content=response.content))

        typing_slot.markdown(f"""
        <div class="chat-row bot">
            <div class="avatar bot">{cfg['emoji']}</div>
            <div class="bubble bot">{response.content}</div>
        </div>""", unsafe_allow_html=True)
