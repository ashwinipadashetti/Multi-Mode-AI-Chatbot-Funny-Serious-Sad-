        "bubble_user_text": "#0d0d0d",
        "bubble_bot": "#1e1c14",
        "bubble_bot_border": "#3a360f",
        "avatar_bg": "#1e1c14",
        "tag": "HUMOR MODE",
    },
    "Serious": {
        "prompt": "You are a serious AI agent. You respond with seriousness and professionalism.",
        "emoji": "🧠",
        "label": "Serious",
        "accent": "#4f8ef5",
        "bubble_user": "#4f8ef5",
        "bubble_user_text": "#ffffff",
        "bubble_bot": "#111824",
        "bubble_bot_border": "#1e3258",
        "avatar_bg": "#111824",
        "tag": "PROFESSIONAL MODE",
    },
    "Sad": {
        "prompt": "You are a sad AI agent. You respond with sadness and empathy.",
        "emoji": "🥺",
        "label": "Sad",
        "accent": "#9b8ecf",
        "bubble_user": "#9b8ecf",
        "bubble_user_text": "#ffffff",
        "bubble_bot": "#16131e",
